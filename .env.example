# Browser launch
HEADLESS=false
CHROME_PATH=/usr/bin/chromium
CHROME_USER_DATA_DIR=/data/chrome
CHROME_PROFILE_DIR=Default
PRELAUNCH_BROWSER=1
STARTUP_URL=about:blank

# Browser operation behavior
BROWSER_OP_TIMEOUT_MS=60000
NAV_WAIT_UNTIL=domcontentloaded
SEARCH_ENGINES=google

# VNC and noVNC
ENABLE_VNC=1
VNC_PORT=5900
NOVNC_PORT=7900

# Optional HTTP health endpoint
ENABLE_HTTP_HEALTH=1
MCP_API_PORT=3000
MCP_API_HOST=http://localhost
ENABLE_SCREENSHOT_DOWNLOAD_LINK=0
ENABLE_SCREENSHOT_PATH=

# MCP transports
ENABLE_STDIO_MCP=1
ENABLE_HTTP_MCP=0

# Search execution (per engine, window-only)
# Keep at least this many warm windows open per engine
SEARCH_KEEP_MIN_WORKING_WINDOWS=2
# Maximum concurrent working windows per engine
SEARCH_MAX_WORKING_WINDOWS=10
# open_page items run in separate windows (no newPage tab spawning)
OPEN_PAGE_MAX_PARALLEL=6
MAX_CONCURRENT_PAGE_OPS=30
# Human typing delay in ms (per character)
HUMAN_TYPING_DELAY=15
