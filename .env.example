# Environment Configuration Template
# ================================
# Copy this file to .env and adjust values as needed.
# These defaults are mirrored in docker-compose.yml environment section.

# ============================================================================
# Browser Launch - Controls how Chromium starts
# ============================================================================
HEADLESS=true               # Run browser without UI (true/false)
CHROME_PATH=/usr/bin/chromium
CHROME_USER_DATA_DIR=/data/chrome    # Persistent Chrome profile directory
CHROME_PROFILE_DIR=Default           # Chrome profile folder name
PRELAUNCH_BROWSER=1                 # Pre-launch browser on server start
STARTUP_URL=about:blank             # URL to open on startup

# ============================================================================
# Browser Operation - Runtime behavior
# ============================================================================
BROWSER_OP_TIMEOUT_MS=25000     # Timeout for browser operations (ms)
NAV_WAIT_UNTIL=domcontentloaded  # Navigation wait strategy: load, domcontentloaded, networkidle0, networkidle2
HUMAN_TYPING_DELAY=0             # Delay per character (ms); set 0 for high-load throughput
ENABLE_HANG_RESTART=0            # Exit process on hung top-level browser ops so Docker can restart
HANG_RESTART_TIMEOUT_MS=120000   # Hang threshold for forced restart (ms)

# ============================================================================
# Search Engine Windows - Concurrent window management per engine
# ============================================================================
SEARCH_ENGINES=bing,duckduckgo,google  # Active search engines (comma-separated)
SEARCH_KEEP_MIN_WORKING_WINDOWS=2      # Min warm windows to keep open per engine
SEARCH_MAX_WORKING_WINDOWS=4           # Max concurrent windows per engine
OPEN_PAGE_MAX_PARALLEL=4              # Max parallel open_page operations
MAX_CONCURRENT_PAGE_OPS=30            # Global max concurrent page operations

# ============================================================================
# VNC and noVNC - Remote browser viewing
# ============================================================================
ENABLE_VNC=1              # Enable VNC server (1=yes, 0=no)
VNC_PORT=5900             # VNC port (5900 = VNC standard)
NOVNC_PORT=7900           # noVNC web interface port

# ============================================================================
# HTTP API Server - REST endpoints (shares MCP_API_PORT)
# ============================================================================
ENABLE_HTTP_HEALTH=1             # Enable HTTP health endpoint at /health
MCP_API_PORT=3000                 # Port for HTTP API (serves /health, /mcp if HTTP_MCP enabled, /download)
MCP_API_HOST=http://localhost     # Host binding for API server

# ============================================================================
# MCP Transports - How MCP server communicates
# ============================================================================
ENABLE_STDIO_MCP=1          # Enable stdio transport (for Claude Desktop/VSCode)
ENABLE_HTTP_MCP=1           # Enable Streamable HTTP transport at /mcp (uses MCP_API_PORT)

# ============================================================================
# Screenshots - Download and storage options
# ============================================================================
ENABLE_SCREENSHOT_DOWNLOAD_LINK=0  # Enable screenshot download at /download/{id}
ENABLE_SCREENSHOT_PATH=            # Custom screenshot storage path (leave empty for default)
